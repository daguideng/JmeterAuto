  </select>


  <!--  查询所的用户信息 -->
  <select id="queryUserByUsername"   resultMap="BaseResultMap">
    select
    *
    from user where username = #{username,jdbcType=VARCHAR} order by id asc
  </select>




  <!-- update email -->
  <update id="updateEmailById" >
    update user set emailaddress = #{email,jdbcType=VARCHAR}
    where id = #{id,jdbcType=INTEGER}
  </update>

  <!-- 禁用用户 -->
  <update id="updateBydisableId" >
    update user set runstate = 1
    where id = #{id,jdbcType=INTEGER}
  </update>

  <!-- 启用用户 -->
