##   To change the RMI/Server port:
##
##   SERVER_PORT=1234 jmeter-server
##





DIRNAME=`dirname $0`

# If the client fails with:
# ERROR - jmeter.engine.ClientJMeterEngine: java.rmi.ConnectException: Connection refused to host: 127.0.0.1
# then it may be due to the server host returning 127.0.0.1 as its address 

# One way to fix this is to define RMI_HOST_DEF below
#RMI_HOST_DEF=-Djava.rmi.server.hostname=xxx.xxx.xxx.xxx


# ============================================================================
# 自定义 JVM 参数配置 - 主要修改这里
# ============================================================================
# 设置堆内存大小：初始值 2GB，最大值 6GB (请根据您的Agent机器总内存调整)
#HEAP="-Xms2g -Xmx4g"
# 设置元空间大小（替代PermGen）
#METASPACE="-XX:MaxMetaspaceSize=512m"
# 使用G1垃圾回收器，在大内存环境下性能更好
#GC="-XX:+UseG1GC"
# 其他优化参数
#OTHER_OPTS="-XX:MaxGCPauseMillis=200 -XX:DisableExplicitGC -XX:+ParallelRefProcEnabled"

# 组合所有JVM参数
#JVM_ARGS="$HEAP $METASPACE $GC $OTHER_OPTS"

# 导出JVM_ARGS环境变量，jmeter脚本会识别这个变量
#export JVM_ARGS

# 如果客户端连接失败，出现 Connection refused to host: 127.0.0.1，取消下一行的注释并替换为服务器的真实IP
# RMI_HOST_DEF=-Djava.rmi.server.hostname=YOUR_ACTUAL_SERVER_IP







${DIRNAME}/jmeter ${RMI_HOST_DEF} -Dserver_port=${SERVER_PORT:-1099} -s -j jmeter-server.log "$@"
